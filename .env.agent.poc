# Blue Agent — POC / Development Configuration (CPU or small GPU)
#
# Default config — works out of the box on a laptop (16GB RAM).

# ── Model ──────────────────────────────────────────────────────────
# Qwen 2.5 7B — fast, good tool calling, runs on CPU or 8GB GPU
LLM_MODEL=qwen2.5:7b-instruct

# Alternatives:
# LLM_MODEL=llama3.1:8b-instruct-q4_K_M     # Alternate 8B model
# LLM_MODEL=mistral:7b-instruct             # Fastest
# LLM_MODEL=qwen2.5:14b-instruct-q4_K_M     # Needs 10GB VRAM

LLM_MAX_TOKENS=2048
OLLAMA_NUM_PARALLEL=2

ALLOW_WRITE_TOOLS=true
REQUIRE_APPROVAL=true
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3400
