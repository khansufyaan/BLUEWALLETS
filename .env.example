PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# HSM configured at runtime via ceremony wizard
# HSM_PKCS11_LIB=/opt/lunaclient/libs/64/libCryptoki2.so
# HSM_SLOT_INDEX=0
# HSM_PIN=your-co-pin

# HSM Label for the partition (optional)
# HSM_LABEL=waas-dpod

# For SoftHSM2 development mode (no hardware HSM required)
# HSM_USE_SOFTHSM=true
# SOFTHSM_LIB=/usr/lib/x86_64-linux-gnu/softhsm/libsofthsm2.so
