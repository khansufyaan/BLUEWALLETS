# Blue Agent — Production Configuration (Llama 3.1 70B + GPU)
#
# Copy this to .env.agent when running with GPU:
#   cp .env.agent.production .env.agent
#
# Hardware requirements:
#   - NVIDIA GPU with 48GB+ VRAM (A100 40GB, H100 80GB, or 2x A6000 48GB)
#   - nvidia-container-toolkit installed on host
#   - ~45GB disk space for model weights

# ── Model ──────────────────────────────────────────────────────────
# Llama 3.1 70B Instruct (4-bit quantized — best balance for banking)
LLM_MODEL=llama3.1:70b-instruct-q4_K_M

# Alternatives:
# LLM_MODEL=llama3.1:70b-instruct-q8_0          # Higher quality, 70GB VRAM
# LLM_MODEL=qwen2.5:72b-instruct-q4_K_M         # Qwen 72B — strong at tool calling
# LLM_MODEL=llama3.3:70b-instruct-q4_K_M        # Llama 3.3 — newest
# LLM_MODEL=mixtral:8x22b-instruct-q4_K_M       # MoE, 141B params, 88GB VRAM

LLM_MAX_TOKENS=4096

# ── Concurrency ────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=1

# ── Agent behavior ─────────────────────────────────────────────────
ALLOW_WRITE_TOOLS=true
REQUIRE_APPROVAL=true
LOG_LEVEL=info

# ── Security ───────────────────────────────────────────────────────
INTERNAL_AUTH_KEY=CHANGE_ME_PROD_AUTH_KEY_32_HEX_BYTES
AGENT_AUTH_KEY=CHANGE_ME_AGENT_SHARED_SECRET_32_HEX
CORS_ORIGIN=https://console.yourbank.internal
