# ============================================================
# Blue Wallets — Environment Configuration Template
#
# BEFORE FIRST RUN:
#   cp .env.example .env
#   ./setup.sh           # auto-generates secrets for you
#
# Or manually edit this file and replace the REPLACE_ME values,
# then rename to .env
# ============================================================

# ── REQUIRED ───────────────────────────────────────────────────
# Postgres password — 16+ chars, mixed case + symbols
# Generate with:   openssl rand -base64 24 | tr -d '=/+' | head -c 24
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Shared secret between Driver and Console — must be 64 hex chars
# Generate with:   openssl rand -hex 32
INTERNAL_AUTH_KEY=REPLACE_ME_WITH_64_HEX_CHARS

# ── OPTIONAL ───────────────────────────────────────────────────

# Blockchain RPC endpoint (default uses public demo key — rate limited)
# For production, sign up at Alchemy/Infura and paste your URL here
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/demo
ETH_CHAIN_ID=11155111

# Restrict browser CORS origin to your Console URL
# Leave blank to disable CORS (all cross-origin requests blocked — safest default)
CORS_ORIGIN=

# Port overrides (defaults: Driver=443, Internal=3200, Console API=3300, Console UI=3400)
# DRIVER_PORT=443
# INTERNAL_PORT=3200

# Log verbosity: info (default), debug, warn, error
LOG_LEVEL=info

# Optional webhook for deposit notifications
WEBHOOK_URL=

# ── AI Agent (Optional) ────────────────────────────────────────
# Only needed if running docker-compose.agent.yml

# Which LLM model to use (default: qwen2.5:7b-instruct — CPU friendly)
# For production with GPU: llama3.1:70b-instruct-q4_K_M
LLM_MODEL=qwen2.5:7b-instruct

# Ollama resource caps (defaults fit a 16GB VM; lower for CPU-only, higher for GPU)
OLLAMA_MEM_LIMIT=16G
OLLAMA_CPU_LIMIT=4
OLLAMA_NUM_PARALLEL=2

# If running agent and you want to require an auth header between
# the Console proxy and the agent service:
# AGENT_AUTH_KEY=<generate with: openssl rand -hex 32>
AGENT_AUTH_KEY=
